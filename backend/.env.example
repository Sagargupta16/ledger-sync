# Ledger Sync Backend Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# Environment
# =============================================================================
# Options: development, staging, production
LEDGER_SYNC_ENVIRONMENT=development

# =============================================================================
# Database Configuration
# =============================================================================
# For development (SQLite):
LEDGER_SYNC_DATABASE_URL=sqlite:///./ledger_sync.db

# For production (PostgreSQL recommended):
# LEDGER_SYNC_DATABASE_URL=postgresql://user:password@localhost:5432/ledger_sync

# Enable SQL query logging (disable in production)
LEDGER_SYNC_DATABASE_ECHO=false

# =============================================================================
# JWT Authentication (CRITICAL - Change for production!)
# =============================================================================
# Generate a secure secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
# WARNING: The default value is for development only!
LEDGER_SYNC_JWT_SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# Token expiration settings (defaults: 30 min access, 7 day refresh)
# LEDGER_SYNC_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# LEDGER_SYNC_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# OAuth (at least one provider required for login)
# =============================================================================
# Google: https://console.cloud.google.com/apis/credentials
# LEDGER_SYNC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# LEDGER_SYNC_GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub: https://github.com/settings/developers
# LEDGER_SYNC_GITHUB_CLIENT_ID=your-github-client-id
# LEDGER_SYNC_GITHUB_CLIENT_SECRET=your-github-client-secret

# Frontend URL for OAuth redirect callbacks
# LEDGER_SYNC_FRONTEND_URL=http://localhost:5173

# =============================================================================
# Logging Configuration
# =============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LEDGER_SYNC_LOG_LEVEL=INFO

# =============================================================================
# Data Directory
# =============================================================================
# For temporary files and exports
LEDGER_SYNC_DATA_DIR=./data
