flowchart TB
    HTTP["HTTP request"]

    subgraph EDGE["Application boundary"]
        MIDDLEWARE["CORS, timing, security,<br/>cache, GZip, rate limits"]
        AUTH["JWT decode<br/>token_version check<br/>CurrentUser"]
        SESSION["Request-scoped<br/>SQLAlchemy session"]
        SCHEMAS["Pydantic schemas"]
    end

    subgraph ROUTERS["FastAPI routers"]
        R_AUTH["OAuth and auth"]
        R_LEDGER["Upload and transactions"]
        R_ANALYTICS["Analytics and calculations"]
        R_PLANNING["Preferences, budgets,<br/>goals, rules, saved views"]
        R_AI["AI chat, tools, usage"]
        R_RATES["Rates, stock prices,<br/>reports, metadata"]
    end

    subgraph CORE["Domain and service layer"]
        C_AUTH["Auth service<br/>JWT + encryption"]
        C_SYNC["Sync engine<br/>normalizer + reconciler"]
        C_ANALYTICS["Analytics engine<br/>rollups + anomalies"]
        C_CALC["Financial calculations<br/>and query helpers"]
        C_AI["15 user-scoped<br/>read-only AI tools"]
        C_PROVIDER["OAuth, Bedrock,<br/>rate providers"]
    end

    subgraph CLI["CLI file path"]
        FILES["Excel / CSV loaders"]
    end

    subgraph DATA["Data layer"]
        MODELS["SQLAlchemy models<br/>8 domain modules"]
        MIGRATIONS["Alembic<br/>33 revisions"]
        DB[("SQLite local<br/>PostgreSQL 17 production")]
    end

    HTTP --> MIDDLEWARE --> AUTH
    AUTH --> ROUTERS
    SESSION --> ROUTERS
    SCHEMAS --> ROUTERS

    R_AUTH --> C_AUTH
    R_LEDGER --> C_SYNC
    R_ANALYTICS --> C_ANALYTICS
    R_ANALYTICS --> C_CALC
    R_PLANNING --> C_CALC
    R_AI --> C_AI
    R_RATES --> C_PROVIDER
    FILES --> C_SYNC

    C_AUTH --> MODELS
    C_SYNC --> MODELS
    C_ANALYTICS --> MODELS
    C_CALC --> MODELS
    C_AI --> MODELS
    MODELS --> DB
    MIGRATIONS --> DB

