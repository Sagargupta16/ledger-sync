flowchart TB
    subgraph API["  API Layer  (FastAPI Routers)  "]
        R1["auth\noauth"]
        R2["upload"]
        R3["transactions"]
        R4["analytics\nanalytics_v2"]
        R5["calculations"]
        R6["preferences"]
        R7["account\nclassifications"]
        R8["meta"]
    end

    subgraph CORE["  Business Logic Layer  "]
        S1["Sync Engine"]
        S2["Reconciler"]
        S3["Calculator"]
        S4["Analytics Engine"]
        S5["Query Helpers\n(shared SQL\naggregations)"]
        S6["Time Filter"]
    end

    subgraph INGEST["  Ingestion Layer  "]
        E1["Excel Loader"]
        E2["Normalizer"]
        E3["Validator"]
        E4["Hash ID\nGenerator"]
        E1 --> E2 --> E3 --> E4
    end

    subgraph DATA["  Data Access Layer  "]
        ORM["SQLAlchemy 2.0\nModels"]
        MIG["Alembic\nMigrations"]
    end

    JWT{{"JWT Auth\nMiddleware\n(deps.py)"}} --> API
    R1 -->|token mgmt| ORM
    R2 --> S1 --> INGEST
    E4 --> S2
    R3 --> S3
    R4 --> S4
    R5 --> S3
    S3 & S4 --> S5
    S5 --> S6
    S2 & S6 --> ORM
    ORM --> DB[("PostgreSQL\nSQLite (dev)")]

