flowchart TB
    subgraph CLIENT["Browser"]
        direction LR
        FILE["Excel or CSV"]
        PARSE["Lazy SheetJS parse"]
        MAP["Map columns<br/>and validate rows"]
        HASH["SHA-256 raw-file hash"]
        FILE --> PARSE --> MAP --> HASH
    end

    subgraph API["Authenticated JSON API"]
        direction LR
        REQUEST["POST /api/upload<br/>file_name, file_hash,<br/>rows, force"]
        NORMALIZE["Normalize values"]
        IDENTIFY["Build occurrence-aware<br/>transaction IDs"]
        RECONCILE["User-scoped reconcile<br/>insert, update, skip,<br/>soft-delete stale"]
        COMMIT["Commit ledger changes"]
        REQUEST --> NORMALIZE --> IDENTIFY --> RECONCILE --> COMMIT
    end

    subgraph ANALYTICS["Analytics consistency"]
        direction LR
        REFRESH["Full analytics refresh"]
        ROLLUPS[("Daily, monthly, category,<br/>FY, cohort, net-worth<br/>and holding rollups")]
        REFRESH --> ROLLUPS
    end

    RESPONSE["Upload response<br/>processed, inserted,<br/>updated, deleted,<br/>unchanged"]
    INVALIDATE["Frontend invalidates<br/>ledger and analytics queries"]

    HASH -->|structured JSON, not multipart| REQUEST
    COMMIT --> REFRESH
    ROLLUPS --> RESPONSE
    REFRESH -. refresh failure does not roll back import .-> RESPONSE
    RESPONSE --> INVALIDATE
    INVALIDATE -. optional reliability pass .-> REFRESH

    style FILE fill:#dbeafe,color:#17201d,stroke:#2563eb,stroke-width:2px
    style PARSE fill:#e0f2fe,color:#17201d,stroke:#0369a1,stroke-width:2px
    style MAP fill:#e0f2fe,color:#17201d,stroke:#0369a1,stroke-width:2px
    style HASH fill:#e0f2fe,color:#17201d,stroke:#0369a1,stroke-width:2px
    style REQUEST fill:#dcfce7,color:#17201d,stroke:#15803d,stroke-width:2px
    style NORMALIZE fill:#dcfce7,color:#17201d,stroke:#15803d,stroke-width:2px
    style IDENTIFY fill:#dcfce7,color:#17201d,stroke:#15803d,stroke-width:2px
    style RECONCILE fill:#fef3c7,color:#17201d,stroke:#b45309,stroke-width:2px
    style COMMIT fill:#dcfce7,color:#17201d,stroke:#15803d,stroke-width:2px
    style REFRESH fill:#ede9fe,color:#17201d,stroke:#6d28d9,stroke-width:2px
    style ROLLUPS fill:#f3e8ff,color:#17201d,stroke:#7e22ce,stroke-width:2px
    style RESPONSE fill:#ffedd5,color:#17201d,stroke:#c2410c,stroke-width:2px
    style INVALIDATE fill:#fee2e2,color:#17201d,stroke:#b91c1c,stroke-width:2px
