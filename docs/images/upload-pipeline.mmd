%%{init: {'theme': 'dark', 'themeVariables': {'primaryColor': '#6366f1', 'primaryTextColor': '#fff', 'primaryBorderColor': '#818cf8', 'lineColor': '#94a3b8', 'secondaryColor': '#1e293b', 'tertiaryColor': '#0f172a', 'background': '#0f172a', 'mainBkg': '#1e293b', 'nodeBorder': '#334155', 'clusterBkg': '#1e293b', 'clusterBorder': '#334155', 'titleColor': '#f8fafc', 'edgeLabelBackground': '#1e293b'}}}%%
flowchart LR
    subgraph INPUT["  Upload  "]
        FILE["Excel File\n(drag & drop)"]
    end

    subgraph INGEST["  Ingestion Pipeline  "]
        direction LR
        LOAD["Excel\nLoader"] --> NORM["Normalizer\n(clean &\nstandardize)"]
        NORM --> VALID["Validator\n(integrity\ncheck)"]
        VALID --> HASH["Hash ID\nGenerator\n(SHA-256)"]
    end

    subgraph RECONCILE["  Reconciliation Engine  "]
        RECON{"Compare\nhash_id\nwith DB"}
        INSERT["INSERT\n(new)"]
        UPDATE["UPDATE\n(changed)"]
        SKIP["SKIP\n(identical)"]
        DELETE["SOFT DELETE\n(stale)"]
        RECON --> INSERT
        RECON --> UPDATE
        RECON --> SKIP
        RECON --> DELETE
    end

    subgraph STORE["  PostgreSQL  "]
        TXN[("transactions\ntable")]
    end

    subgraph RESPONSE["  API Response  "]
        RES["{created: N\nupdated: N\ndeleted: N\nskipped: N}"]
    end

    FILE --> LOAD
    HASH --> RECON
    INSERT & UPDATE & DELETE --> TXN
    TXN --> RES

    style FILE fill:#6366f1,color:#fff,stroke:#818cf8,stroke-width:2px
    style LOAD fill:#3b82f6,color:#fff,stroke:#60a5fa,stroke-width:2px
    style NORM fill:#3b82f6,color:#fff,stroke:#60a5fa,stroke-width:2px
    style VALID fill:#3b82f6,color:#fff,stroke:#60a5fa,stroke-width:2px
    style HASH fill:#3b82f6,color:#fff,stroke:#60a5fa,stroke-width:2px
    style RECON fill:#f59e0b,color:#000,stroke:#fbbf24,stroke-width:2px
    style TXN fill:#10b981,color:#fff,stroke:#34d399,stroke-width:2px
    style INSERT fill:#22c55e,color:#fff,stroke:#4ade80,stroke-width:2px
    style UPDATE fill:#3b82f6,color:#fff,stroke:#60a5fa,stroke-width:2px
    style SKIP fill:#6b7280,color:#fff,stroke:#9ca3af,stroke-width:2px
    style DELETE fill:#ef4444,color:#fff,stroke:#f87171,stroke-width:2px
    style RES fill:#8b5cf6,color:#fff,stroke:#a78bfa,stroke-width:2px
